{
  "version": 2,
  "buildCommand": "cd ../.. && npm run build:packages && npm run build:api",
  "installCommand": "cd ../.. && npm install",
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/dist/index.js" }
  ]
}
