# ============================================================================
# PDE — Level-D Environment Variables
# Programmable Data Exchange  |  Agent-to-Agent  |  Stellar Testnet
# ============================================================================
#
# Copy this file to .env.local (never commit .env.local).
# All values marked (REQUIRED) must be set before the system starts.
# Values marked (OPTIONAL) have working defaults for local dev.
#
# ── How to get each value is explained inline ──────────────────────────────
# ============================================================================


# ────────────────────────────────────────────────────────────────────────────
# STELLAR — Platform Keypair
# ────────────────────────────────────────────────────────────────────────────
#
# The "platform" account is the PDE server's on-chain identity.
# It receives the 20% platform share on every escrow release.
# It is also the admin that can resolve disputes via resolve_batch().
#
# How to generate:
#   stellar keys generate platform --network testnet --fund
#   stellar keys show platform
#
# Fund with testnet XLM:
#   https://laboratory.stellar.org (Friendbot tab)
#   OR: curl "https://friendbot.stellar.org?addr=<PUBLIC_KEY>"
#
# (REQUIRED)
STELLAR_PLATFORM_PUBLIC=GBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_PLATFORM_SECRET=SBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ────────────────────────────────────────────────────────────────────────────
# SOROBAN — Deployed Contract IDs
# ────────────────────────────────────────────────────────────────────────────
#
# How to build and deploy the escrow contract:
#
#   cd contracts/escrow
#   stellar contract build
#   stellar contract deploy \
#     --wasm target/wasm32-unknown-unknown/release/escrow.wasm \
#     --source platform \
#     --network testnet
#   → outputs: C... (contract ID)
#
#   Then initialize (one-time):
#   stellar contract invoke \
#     --id <CONTRACT_ID> --source platform --network testnet \
#     -- initialize --admin <STELLAR_PLATFORM_PUBLIC>
#
# Repeat with contracts/registry/ for the CID registry contract.
#
# (REQUIRED)
SOROBAN_ESCROW_CONTRACT=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SOROBAN_REGISTRY_CONTRACT=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Soroban RPC endpoint (testnet default below — OK for MVP)
# (OPTIONAL)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org


# ────────────────────────────────────────────────────────────────────────────
# USDC — Stellar Asset Contract (testnet)
# ────────────────────────────────────────────────────────────────────────────
#
# This is the canonical USDC SAC address on Stellar testnet.
# Do NOT change this unless you are using a different token.
#
# Buyer/seller wallets must:
#   1. Add a trustline: changeTrust → asset=USDC, issuer=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
#   2. Get test USDC: https://circle.com/faucet (select Stellar)
#
# (OPTIONAL — default is testnet USDC SAC)
USDC_TESTNET_SAC=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
# USDC issuer (for trustline setup)
USDC_TESTNET_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN


# ────────────────────────────────────────────────────────────────────────────
# IPFS — Pinata
# ────────────────────────────────────────────────────────────────────────────
#
# Both buyer and seller agents upload JSON and encrypted payloads to IPFS.
# The platform server also uploads proof audit records.
#
# How to get:
#   1. Go to https://pinata.cloud → Sign Up (free tier: 1 GB)
#   2. Dashboard → API Keys → New Key → Admin → Create
#   3. Copy the JWT (not the API key/secret — use the JWT)
#
# (REQUIRED)
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXX

# Public IPFS gateway for reading (Pinata dedicated gateway or public)
# (OPTIONAL — default below works for testnet)
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# If you have a Pinata dedicated gateway (paid plan):
# PINATA_GATEWAY_URL=https://YOUR-GATEWAY.mypinata.cloud


# ────────────────────────────────────────────────────────────────────────────
# ZK-TLS — Self-Hosted Attestor-Core
# ────────────────────────────────────────────────────────────────────────────
#
# attestor-core is the TLS witness that fetches source API data and signs
# the claim with ed25519. Without it, all ZK proofs are SIMULATED.
#
# How to run attestor-core:
#   git clone https://github.com/reclaimprotocol/attestor-core
#   cd attestor-core
#   npm install
#   PRIVATE_KEY=$(openssl rand -hex 32) npm run start:tsc
#   → Starts on http://localhost:8001
#
# Then get the public key:
#   curl http://localhost:8001/info | jq .publicKey
#   → Copy the hex string → paste into ATTESTOR_PUBLIC_KEYS
#
# For production: deploy on a VPS, set ATTESTOR_URL to its public URL.
#
# (REQUIRED for real ZK proofs; leave blank for simulated mode)
ATTESTOR_URL=http://localhost:8001

# Comma-separated hex ed25519 public keys of trusted attestors.
# If empty: dev mode — any valid ed25519 signature accepted (insecure!).
# If set: at least one signature must come from a listed key.
# (REQUIRED for production)
ATTESTOR_PUBLIC_KEYS=


# ────────────────────────────────────────────────────────────────────────────
# x402 Micro-Payments — OpenZeppelin Relayer
# ────────────────────────────────────────────────────────────────────────────
#
# x402 is used for per-batch micropayments from buyer to seller.
# OpenZeppelin Relayer acts as the x402 facilitator on Stellar testnet.
#
# How to get:
#   1. https://openzeppelin.com/defender (testnet access)
#   OR use the public testnet facilitator (no key required for testnet):
#
# (OPTIONAL — default testnet facilitator below)
X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
X402_API_KEY=


# ────────────────────────────────────────────────────────────────────────────
# NEXTAUTH — Web Dashboard Authentication
# ────────────────────────────────────────────────────────────────────────────
#
# NextAuth uses Stellar wallet signature for authentication (no passwords).
# NEXTAUTH_SECRET can be any random string (32+ chars).
#
# Generate: openssl rand -hex 32
#
# (REQUIRED for web dashboard)
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_32_CHAR_HEX
NEXTAUTH_URL=http://localhost:3000


# ────────────────────────────────────────────────────────────────────────────
# OPENCLAW — Agent Bot Configuration
# ────────────────────────────────────────────────────────────────────────────
#
# OpenClaw is the WhatsApp/Telegram/Discord gateway for buyer and seller bots.
# Each bot needs its own Stellar keypair to sign transactions.
#
# Buyer agent keypair (the bot that creates skills + pays for data):
#   stellar keys generate buyer-agent --network testnet --fund
BUYER_AGENT_STELLAR_PUBLIC=GBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BUYER_AGENT_STELLAR_SECRET=SBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Seller agent keypair (the bot that delivers data + calls deliver_batch):
#   stellar keys generate seller-agent --network testnet --fund
SELLER_AGENT_STELLAR_PUBLIC=GBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SELLER_AGENT_STELLAR_SECRET=SBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenClaw webhook URL (where PDE server sends consent + escrow events)
# See AGENT.md for full bot setup.
# (OPTIONAL — agents also listen via Horizon SSE directly)
OPENCLAW_WEBHOOK_URL=https://your-openclaw-instance/hooks/agent


# ────────────────────────────────────────────────────────────────────────────
# PDE API — Governance Layer (Optional)
# ────────────────────────────────────────────────────────────────────────────
#
# The API is optional — agents communicate via Stellar+IPFS directly.
# Set these only if you are running the apps/api server.

# CORS origin for the API (set to your frontend URL in production)
# (OPTIONAL)
CORS_ORIGIN=http://localhost:3000

# Port for the API server (default 3001)
# (OPTIONAL)
PORT=3001

# NODE_ENV — "development" or "production"
# (OPTIONAL)
NODE_ENV=development


# ────────────────────────────────────────────────────────────────────────────
# HORIZON — Stellar Testnet SSE Stream
# ────────────────────────────────────────────────────────────────────────────
#
# Agents use Horizon SSE to detect on-chain events (skills, consents, escrow).
# The default testnet URL below works without any account.
#
# (OPTIONAL — defaults used internally by packages/stellar)
HORIZON_URL=https://horizon-testnet.stellar.org


# ────────────────────────────────────────────────────────────────────────────
# SUMMARY — Minimum required for each level
# ────────────────────────────────────────────────────────────────────────────
#
# Level A (simulation only — no infra):
#   NEXTAUTH_SECRET, NEXTAUTH_URL
#
# Level B (real Soroban escrow, simulated proofs):
#   + STELLAR_PLATFORM_PUBLIC/SECRET
#   + SOROBAN_ESCROW_CONTRACT
#   + SOROBAN_REGISTRY_CONTRACT
#   + PINATA_JWT
#
# Level C (real ZK-TLS proofs):
#   + ATTESTOR_URL
#   + ATTESTOR_PUBLIC_KEYS
#
# Level D (full agent-to-agent autonomous):
#   + BUYER_AGENT_STELLAR_PUBLIC/SECRET
#   + SELLER_AGENT_STELLAR_PUBLIC/SECRET
#   + X402_FACILITATOR_URL (+ X402_API_KEY if mainnet)
#   + OPENCLAW_WEBHOOK_URL
# ============================================================================
